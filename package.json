{
  "name": "loyalty-platform",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @loyalty/api dev",
    "dev:bot": "pnpm --filter @loyalty/bot dev",
    "dev:admin": "pnpm --filter @loyalty/admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}